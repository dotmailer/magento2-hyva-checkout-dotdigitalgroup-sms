        }"
        @submit="ShippingFormSubmit"
        method="post"
        class="w-full max-w-lg p-4">

        <header class="section-title border-b border-gray-400 pb-1 mt-6">
            <h2 class="text-gray-800 text-xl font-medium">
                <?= __('Phone number and marketing consent') ?>
            </h2>
        </header>

        <div class="flex flex-wrap -mx-3 mb-6">
            <h1> <?=$magewire->isValid; ?></h1>
