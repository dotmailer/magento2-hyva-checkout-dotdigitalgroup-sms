    </form>

<script>

    window.addEventListener('magewire:load', () => {
        Magewire.hook('element.updated', (el, component) => {
            if (component.id === 'checkout.shipping-details.address-list') {
                Livewire.emit('address_list_updated')
            }
        }, {once: true});
    }, {once: true});


    async function ShippingFormSubmit(event) {
        event.preventDefault()

        const formData = new FormData(this.$el)
        const payload = {}
        for( [key, value] of formData.entries() ) {
            payload[key] = value
        }

        try {
             await this.validate()
        } catch (e) {
            return
        }

        this.$wire.formSubmit(payload)
        Livewire.emit('shipping_phone_number_updated')

    }
</script>
